<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Chat Room</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/chat.css">
</head>

<body class="d-flex flex-column vh-100" data-user-id="<%= user.id %>">

<nav class="navbar border-bottom sticky-top">
    <div class="container-fluid max-width-1000">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/chat">
            <img src="/images/chatapp.png" alt="Logo" width="45" height="40" class="rounded-3 shadow-sm">
            <span class="fw-bold brand-font h4 mb-0">ChatApp</span>
        </a>

        <div class="d-flex align-items-center gap-3">
            <div class="text-end d-none d-sm-block">
                <small class="text-muted d-block" style="font-size:13px;">Welcome back</small>
                <span class="fw-semibold small text-dark"><%- typeof user !== 'undefined' ? user.firstName : '' %></span>
            </div>
            <div class="avatar-circle">
                <%- typeof user !== 'undefined' ? user.firstName.charAt(0).toUpperCase() : '?' %>
            </div>
            <form action="/logout" method="POST" class="m-0">
                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Logout</button>
            </form>
        </div>
    </div>
</nav>

<main class="container-fluid max-width-1000 flex-grow-1 d-flex flex-column p-3">

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger py-2 small"><%- error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success py-2 small"><%- success %></div>
    <% } %>
    <div id="errorMsg" class="alert alert-danger d-none py-2 small"></div>

    <form action="/chat/search" method="GET" class="search-bar input-group input-group-sm mb-3">
        <input type="text" name="q" class="form-control ps-3"
               placeholder="🔍 Search in clouds..."
               aria-label="Search messages"
               maxlength="100"
               value="<%- typeof query !== 'undefined' && query ? query.replace(/"/g, '&quot;') : '' %>">
        <button class="btn btn-white border-start" type="submit">Search</button>
        <% if (typeof query !== 'undefined' && query) { %>
            <a href="/chat" class="btn btn-white border-start text-danger">Clear</a>
        <% } %>
    </form>

    <div id="chatMessages" class="messages-container flex-grow-1 p-3 mb-3 custom-scrollbar">
        <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
            <% messages.forEach(function(msg) {
                // Safely escape content for data attribute
                const safeContent = String(msg.content || '')
                        .replace(/&/g, '&amp;')
                        .replace(/"/g, '&quot;')
                        .replace(/'/g, '&#039;')
                        .replace(/</g, '&lt;')
                        .replace(/>/g, '&gt;');
            %>
            <div class="d-flex mb-4 <%= msg.userId === user.id ? 'justify-content-end my-message' : 'other-message' %>">

                <% if (msg.userId !== user.id) { %>
                    <div class="avatar-sm me-2">
                        <%- msg.sender.firstName.charAt(0).toUpperCase() %>
                    </div>
                <% } %>

                <div class="message-wrapper" style="max-width: 75%;">
                    <div class="d-flex align-items-center gap-2 mb-1 <%= msg.userId === user.id ? 'justify-content-end' : '' %>">
                        <span class="fw-bold small text-dark opacity-75"><%- msg.sender.firstName %></span>
                        <span class="text-muted" style="font-size: 10px;">
                                <%- new Date(msg.createdAt).toLocaleDateString() %> <%- new Date(msg.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                            </span>
                    </div>

                    <div class="message-bubble <%= msg.userId === user.id ? 'my-bubble' : 'other-bubble' %> shadow-sm">
                        <%= msg.content %>
                    </div>

                    <% if (msg.userId === user.id) { %>
                        <div class="mt-1 d-flex justify-content-end gap-2">
                            <button class="btn-action edit"
                                    data-id="<%= msg.id %>"
                                    data-content="<%= safeContent %>">Edit</button>
                            <form action="/chat/delete/<%= msg.id %>" method="POST" class="d-inline"
                                  onsubmit="return confirm('Are you sure? Deleting a message cannot be undone');">
                                <button type="submit" class="btn-action delete">Delete</button>
                            </form>
                        </div>
                    <% } %>
                </div>

                <% if (msg.userId === user.id) { %>
                    <div class="avatar-sm ms-2">
                        <%- user.firstName.charAt(0).toUpperCase() %>
                    </div>
                <% } %>
            </div>
            <% }); %>
        <% } else { %>
            <div class="text-center py-5 text-muted">
                <div style="font-size: 60px; filter: grayscale(1);">☁️</div>
                <h5 class="mt-3 text-dark fw-bold">No messages yet</h5>
                <p class="small">Say hello 👋</p>
            </div>
        <% } %>
    </div>

    <form action="/chat/add" method="POST" class="input-area d-flex align-items-center p-2">
        <input type="text" name="content" class="form-control border-0 ps-3 bg-transparent text-dark"
               placeholder="Type a message..." maxlength="500" required
               aria-label="Type a message">
        <button type="submit" class="btn btn-send rounded-pill px-4">Send</button>
    </form>

</main>

<script src="/js/chat.js"></script>


<!-- Highlight the searched keyword within the message content -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const urlParams = new URLSearchParams(window.location.search);
        const searchTerm = urlParams.get('q') ? urlParams.get('q').trim() : '';

        if (!searchTerm) return;

        const bubbles = document.querySelectorAll('.message-bubble');

        bubbles.forEach(bubble => {
            const originalText = bubble.textContent;

            const regex = new RegExp(`(${searchTerm})`, 'gi');

            if (originalText.match(regex)) {
                bubble.innerHTML = originalText.replace(regex, '<span class="highlight">$1</span>');
            }
        });
    });
</script>
</body>
</html>